# Private key from your wallet (64 hex characters)
PRIVATE_KEY=your_private_key_here

# RPC endpoint for Polygon Amoy Testnet
POLYGON_RPC_URL=https://rpc-amoy.polygon.technology/

# PolygonScan API key (optional)
POLYGONSCAN_API_KEY=your_api_key_here

# Deployed contract addresses (populated after deployment)
CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000
TEST_TOKEN_ADDRESS=0x0000000000000000000000000000000000000000
